#!/bin/bash
# Validate commit messages against AGENTS.md spec

set -e

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Extract title (first line)
title=$(echo "$commit_msg" | head -1)

# Extract body (everything after first blank line)
body=$(echo "$commit_msg" | tail -n +3)

errors=()

# Skip validation for git autosquash commits
if echo "$title" | grep -qE '^(fixup|squash)! '; then
  exit 0
fi

# Do Checks

# Imperative mood is checked by exclusion, not a verb whitelist: any capitalized
# first word passes unless it is a clearly non-imperative form (gerund -ing,
# past -ed, 3rd-person -s, or a common irregular past). A whitelist rejected
# legitimate imperative verbs (Regenerate, Skip, Fold, Print, ...) far more
# often than it caught real violations, and needed constant extension.
# Returns 0 (ok) if the word looks imperative.
is_imperative() {
  local word="$1"
  echo "$word" | grep -qE '^[A-Z]' || return 1
  # Non-verb sentence-starters (articles, pronouns, demonstratives, conjunctions):
  # none of these carry a verb-inflection suffix, so they'd otherwise fall through
  # every check below and pass by default.
  echo "$word" | grep -qE '^(A|An|The|This|That|These|Those|It|There|Its|They|We|I|He|She)$' && return 1
  # Imperative words that happen to carry a suspicious suffix
  echo "$word" | grep -qE '^(Embed|Speed|Proceed|Exceed|Feed|Seed|Shed|Need|Shred|Bring|Focus|Bias|Alias)$' && return 0
  echo "$word" | grep -qE 'ing$' && return 1        # gerund: Adding, Fixing
  echo "$word" | grep -qE '[^e]ed$|[aiouy]ed$' && return 1  # past: Added, Fixed, Copied
  echo "$word" | grep -qE 'ss$' && return 0          # Pass, Suppress, Address, ...
  echo "$word" | grep -qE 's$' && return 1           # 3rd person: Adds, Fixes
  echo "$word" | grep -qE '^(Made|Kept|Left|Built|Wrote|Rewrote|Sent|Shut|Ran|Gave|Took|Threw|Began|Kept)$' && return 1
  return 0
}
allowable_prefixes='parser|tree|casadi|sympy|xml|cli|test|doc|ci/cd'
prefix_list="$(echo "$allowable_prefixes" | sed 's/|/:, /')"

# Check title length (≤50 chars goal, ≤60 chars hard limit)
title_len=${#title}
if [ "$title_len" -gt 60 ]; then
  errors+=("Title too long ($title_len chars, max 60). Goal: ≤50 chars.")
fi

# Check for valid prefix
if ! echo "$title" | grep -qE "^($allowable_prefixes):\s"; then
  errors+=("Title must start with a prefix ($prefix_list).")
fi

# Check for imperative verb after prefix
title_verb=$(echo "$title" | sed -E 's/^[a-z/]+:[[:space:]]+//' | awk '{print $1}')
if ! is_imperative "$title_verb"; then
  errors+=("Title must use a capitalized imperative verb after the prefix (e.g. 'Add', not 'Adds/Added/Adding').")
fi

# Check body paragraph 1 exists (at least one non-empty line)
if [ -z "$(echo "$body" | head -1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')" ]; then
  errors+=("Body must have at least one paragraph with 1–3 sentences explaining the change.")
fi

# Check that body paragraph 1 begins with an imperative verb
body_verb=$(echo "$body" | sed -n 's/^[[:space:]]*//;s/[[:space:]].*//;1p' | head -1)
if ! is_imperative "$body_verb"; then
  errors+=("Body 1st paragraph must start with a capitalized imperative verb (present tense).")
fi

# 5. Check for meta-commentary (code review references, process artifacts)
meta_keywords=(
  "Closes #"
  "Fixes #"
  "Resolves #"
  "issue #"
  "PR #"
  "pull request"
  "code review"
  "reviewer"
  "merge request"
)

for keyword in "${meta_keywords[@]}"; do
  if echo "$commit_msg" | grep -qi "$keyword"; then
    errors+=("No meta-commentary allowed. Don't mention code review, issues, or process artifacts in the message.")
    break
  fi
done

# Report errors
if [ ${#errors[@]} -gt 0 ]; then
  echo "❌ Commit message validation failed:" >&2
  printf '\n' >&2
  for error in "${errors[@]}"; do
    echo "  • $error" >&2
  done
  printf '\n' >&2
  echo "📖 See AGENTS.md § Git Style for the full spec." >&2
  echo "📖 See $0 for the script that checked your commit message." >&2
  printf '\n' >&2
  echo "This was your message:"
  echo "$commit_msg" >&2
  exit 1
fi

exit 0
