#!/bin/bash
# Validate commit messages against AGENTS.md spec

set -e

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Extract title (first line)
title=$(echo "$commit_msg" | head -1)

# Extract body (everything after first blank line)
body=$(echo "$commit_msg" | tail -n +3)

errors=()

# Skip validation for git autosquash commits
if echo "$title" | grep -qE '^(fixup|squash)! '; then
  exit 0
fi

# Do Checks

allowable_verbs='Add|Fix|Remove|Delete|Update|Refactor|Improve|Change|Allow|Prevent|Handle|Support|Implement|Rename|Reorganize|Simplify|Optimize|Enhance|Make|Set|Include|Exclude|Use|Replace|Move|Copy|Revert|Restore'
allowable_prefixes='parser|tree|casadi|sympy|cli|test|doc|ci/cd'
prefix_list="$(echo "$allowable_prefixes" | sed 's/|/:, /')"

# Check title length (≤50 chars goal, ≤60 chars hard limit)
title_len=${#title}
if [ "$title_len" -gt 60 ]; then
  errors+=("Title too long ($title_len chars, max 60). Goal: ≤50 chars.")
fi

# Check for valid prefix
if ! echo "$title" | grep -qE "^($allowable_prefixes):\s"; then
  errors+=("Title must start with a prefix ($prefix_list).")
fi

# Check for imperative verb after prefix
if ! echo "$title" | grep -qE "^[a-z/]+:\\s($allowable_verbs)(\\s|\\$)"; then
  errors+=("Title must use imperative verb (Add, Fix, Remove, Update, etc.) after the prefix.")
fi

# Check body paragraph 1 exists (at least one non-empty line)
if [ -z "$(echo "$body" | head -1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')" ]; then
  errors+=("Body must have at least one paragraph with 1–3 sentences explaining the change.")
fi

# Check that body paragraph 1 begins with an imperative verb
if ! echo "$body" | grep -qE "^\s*($allowable_verbs)"; then
  errors+=("Body 1st paragraph must start with an imperative verb (present tense).")
fi

# 5. Check for meta-commentary (code review references, process artifacts)
meta_keywords=(
  "Closes #"
  "Fixes #"
  "Resolves #"
  "issue #"
  "PR #"
  "pull request"
  "code review"
  "reviewer"
  "merge request"
)

for keyword in "${meta_keywords[@]}"; do
  if echo "$commit_msg" | grep -qi "$keyword"; then
    errors+=("No meta-commentary allowed. Don't mention code review, issues, or process artifacts in the message.")
    break
  fi
done

# Report errors
if [ ${#errors[@]} -gt 0 ]; then
  echo "❌ Commit message validation failed:" >&2
  printf '\n' >&2
  for error in "${errors[@]}"; do
    echo "  • $error" >&2
  done
  printf '\n' >&2
  echo "📖 See AGENTS.md § Git Style for the full spec." >&2
  exit 1
fi

exit 0
